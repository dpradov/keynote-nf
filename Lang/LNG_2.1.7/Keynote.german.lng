54192_knt_RS_sTree56=Filter auf Baum anwenden
54193_knt_RS_sTree57= (Strg: Suchfilter löschen)
54194_knt_RS_sTree59=Alle Markierungen im Ordner entfernen?
54195_knt_RS_sTree60=Zuletzt geändert >= "%s"
54196_knt_RS_sTree62=Name
54197_knt_RS_sTree63=Name der Notiz
